{
  "name": "search-wizard",
  "version": "26.1.1",
  "description": "Spotlight-style Launcher for SEARCH WIZARD",
  "main": "main.js",
  "author": "Deepan Chandrasekaran",
  "repository": {
    "type": "git",
    "url": "https://github.com/deepanmpc/SMART-SEARCH.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.searchwizard.app",
    "productName": "SEARCH WIZARD",
    "publish": {
      "provider": "github",
      "owner": "deepanmpc",
      "repo": "SMART-SEARCH"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "artifactName": "SEARCHWIZARD_mac.${ext}"
    },
    "win": {
      "target": "nsis",
      "artifactName": "SEARCHWIZARD_windows.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "SEARCHWIZARD_linux.${ext}"
    },
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "buildResources": "assets"
    }
  }
}
